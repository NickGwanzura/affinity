# =============================================================================
# AFFINITY CRM - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Server-side only - NEVER expose to browser)
# -----------------------------------------------------------------------------
# Neon PostgreSQL connection string
# This is used ONLY by API routes (server-side)
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# AUTHENTICATION (Server-side only)
# -----------------------------------------------------------------------------
# JWT secret for signing tokens - generate a strong random string
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
# API base URL (for frontend)
# Use '/api' for same-domain deployment (Vercel)
# Use full URL for separate API deployment
VITE_API_URL=/api

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES (Optional)
# -----------------------------------------------------------------------------
# Google Gemini AI (if using AI features)
# VITE_GEMINI_API_KEY=

# Email service (for password reset emails)
# APP_BASE_URL=https://your-app.example.com

# Resend (recommended - set up at https://resend.com)
RESEND_API_KEY=re_123456789
EMAIL_FROM_ADDRESS=noreply@affinitylogsitics.site

# SMTP (alternative to Resend)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Affinity Logistics <noreply@yourdomain.com>"
# SMTP_REPLY_TO=support@yourdomain.com
# SMTP_SECURE=false

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# OBSERVABILITY (Optional — graceful no-op when unset)
# -----------------------------------------------------------------------------
# Optional — error reporting
SENTRY_DSN=
VITE_SENTRY_DSN=
LOG_LEVEL=info
VITE_LOG_LEVEL=warn

# -----------------------------------------------------------------------------
# RATE LIMITING (Optional)
# -----------------------------------------------------------------------------
# Optional — when unset, rate limit falls back to in-memory (multi-instance bypass)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
