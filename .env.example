# ============================================================
# Affinity Logistics CRM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Neon PostgreSQL (required) ---
# Connection string from your Neon project dashboard
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# Browser-side client (used by current direct-query code — migrate away from this)
VITE_NEON_DATABASE_URL=

# Server-side client for Vercel API functions (never exposed to the browser)
NEON_DATABASE_URL=

# --- JWT Auth (required) ---
# Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
VITE_JWT_SECRET=

# --- Gemini AI (optional) ---
# Found in: Google AI Studio → API Keys
VITE_GEMINI_API_KEY=
